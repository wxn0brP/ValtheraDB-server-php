<?php
/**
 * Database configuration file
 * Supports multiple databases with a shared default configuration.
 *
 * Behavior:
 * - If a database entry is defined as [] or true, the default configuration is used.
 * - In that case, the 'database' value is automatically set to the key name.
 * - If a custom configuration array is provided, its values override the defaults.
 */

 // Hardcoded authentication tokens with descriptive names
$auth = [
    'admin' => 'admin-token-123',
    'app' => 'app-token-456',
    'test' => 'test-token-789',
];

// Default database configuration
$default = [
    'host' => 'localhost',
    'port' => 3306,
    // Intentionally empty. If a database entry does not define it
    // and no automatic name can be assigned, an error will be thrown.
    'database' => '',
    'username' => 'root',
    'password' => '',
    'charset' => 'utf8mb4',
    'driver' => 'auto',
    'options' => [
        PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
        PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
        PDO::ATTR_EMULATE_PREPARES => false,
    ]
];

$databases = [
    // Uses the default configuration.
    // 'database' will automatically be set to 's'.
    's' => [],

    // Custom configuration overriding selected default values.
    // Values defined here take priority over the defaults.
    'sakila' => [
        'host' => 'localhost',
        'port' => 3306,
        'database' => 'sakila',
        'username' => 'pma',
        'password' => 'pma',
        'charset' => 'utf8mb4',
        'driver' => 'mysqli',
    ],
];

return [
    'auth' => $auth,
    'default' => $default,
    'databases' => $databases,
];
